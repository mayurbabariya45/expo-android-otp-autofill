# Exclude all top-level hidden directories by convention
/.*/

# Exclude tarballs generated by `npm pack`
/*.tgz

__mocks__
__tests__

/babel.config.js
/android/src/androidTest/
/android/src/test/
/android/build/
/example/

# Compiled JS not used when main points to src (bundler compiles from source)
build/*.js
build/**/*.js
# Source/declaration maps (debug only, not needed at runtime)
build/*.map
build/**/*.map
